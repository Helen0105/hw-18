    tbody.innerHTML = "";
    students.forEach((student)=>{
        const row = document.createElement('tr');
        row.innerHTML = `
      <td>${student.id}</td>
      <td>${student.name}</td>
      <td>${student.age}</td>
      <td>${student.course}</td>
      <td>${student.skills.join(", ")}</td>
      <td>${student.email}</td>
      <td>${student.isEnrolled ? "\u0422\u0430\u043A" : "\u041D\u0456"}</td>
